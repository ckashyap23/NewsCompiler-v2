# Copy this file to .env and fill in your values.
# Do not commit .env to version control.

# Daily research (orchestrator.py)
OPENAI_API_KEY=your-openai-api-key
OPENAI_NEWSLETTER_MODEL=gpt-4o-mini
RECIPIENT_EMAILS=recipient1@example.com recipient2@example.com
RESEARCH_TOPIC=

# Weekly digest (weekly_digest.py)
WEEKLY_DIGEST_DAYS=7

# Gmail (required for send_email.py)
# Use an App Password (not your regular password): https://myaccount.google.com/apppasswords
# Enter without spaces, e.g. abcdabcdabcdabcd
GMAIL_EMAIL=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# LinkedIn OAuth2 (for weekly_digest.py LinkedIn posting)
# Get these from https://www.linkedin.com/developers/apps
# For Render/headless use, paste a valid access token into LINKEDIN_ACCESS_TOKEN.
LINKEDIN_CLIENT_ID=your-client-id
LINKEDIN_CLIENT_SECRET=your-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:8000/linkedin/callback
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_AUTHOR_URN=urn:li:person:your-member-id
LINKEDIN_API_VERSION=202506

# Database (PostgreSQL for storing research results)
DATABASE_URL=postgresql://user:password@localhost:5432/cnews_compiler
