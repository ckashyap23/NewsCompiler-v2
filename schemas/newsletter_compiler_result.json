{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NewsletterCompilerResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "newsletter_title",
    "opening_hook",
    "key_trends",
    "top_highlights",
    "implications",
    "topics_covered",
    "newsletter_markdown"
  ],
  "properties": {
    "newsletter_title": {
      "type": "string",
      "minLength": 1
    },
    "opening_hook": {
      "type": "string",
      "minLength": 1
    },
    "key_trends": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "trend",
          "description",
          "significance"
        ],
        "properties": {
          "trend": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "significance": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          }
        }
      }
    },
    "top_highlights": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "highlight",
          "description",
          "topics_involved"
        ],
        "properties": {
          "highlight": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "topics_involved": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "implications": {
      "type": "string",
      "minLength": 1
    },
    "topics_covered": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "newsletter_markdown": {
      "type": "string",
      "minLength": 1
    },
    "newsletter_html": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
