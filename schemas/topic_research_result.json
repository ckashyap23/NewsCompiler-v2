{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TopicResearchResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary_markdown",
    "subject",
    "sources"
  ],
  "properties": {
    "summary_markdown": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "url",
          "date"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "date": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}
